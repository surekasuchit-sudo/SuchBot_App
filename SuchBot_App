<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SuchBot - Secured Vault Edition</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: #030303;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            font-family: sans-serif;
            user-select: none;
        }

        /* --- STYLISH VAULT DASHBOARD LAYOUT --- */
        #start-screen {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: #030303; display: flex; justify-content: center; align-items: center;
            z-index: 100; color: #00ffcc;
            text-transform: uppercase; letter-spacing: 4px; font-family: monospace;
            text-shadow: 0 0 10px rgba(0, 255, 200, 0.3);
        }

        .api-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            text-align: center;
        }

        .api-input {
            background: #001111;
            border: 2px solid #005544;
            color: #00ffcc;
            padding: 12px 20px;
            font-family: monospace;
            font-size: 16px;
            border-radius: 8px;
            width: 320px;
            text-align: center;
            outline: none;
            box-shadow: 0 0 10px rgba(0, 255, 200, 0.1);
            transition: all 0.3s;
        }
        .api-input:focus {
            border-color: #00ffcc;
            box-shadow: 0 0 15px rgba(0, 255, 200, 0.4);
        }

        .api-btn {
            background: #005544;
            color: #030303;
            border: none;
            padding: 12px 24px;
            font-family: monospace;
            font-weight: bold;
            font-size: 15px;
            border-radius: 8px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.2s;
        }
        .api-btn:hover {
            background: #00ffcc;
            box-shadow: 0 0 15px #00ffcc;
        }

        /* --- GIANT CLASSIC EYE PLATFORM --- */
        .face-container { 
            display: flex; 
            justify-content: space-around; 
            width: 95vw; 
            max-width: 580px;
            transition: transform 0.25s ease;
        }

        .eye { 
            width: 44vw; height: 44vw; max-width: 230px; max-height: 230px; 
            border-radius: 50%; 
            background-color: #001111; 
            position: relative; overflow: hidden;
            border: 5px solid #005544;
            box-shadow: inset 0 0 30px rgba(0, 255, 200, 0.2), 0 0 15px rgba(0, 85, 68, 0.4);
            display: flex; justify-content: center; align-items: center;
            transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
        }

        .bright-lens { 
            width: 55%; height: 55%; border-radius: 50%; 
            background-color: #00ffcc; 
            box-shadow: 0 0 35px #00ffcc, inset 0 0 10px #ffffff;
            transition: transform 0.15s ease-out, width 0.3s, height 0.3s, background-color 0.3s; 
            position: relative;
        }

        /* --- EXPRESSION MECHANICAL SYSTEM --- */
        .listening .eye {
            animation: cyberBlink 5s infinite;
        }
        @keyframes cyberBlink {
            0%, 92%, 100% { transform: scaleY(1); }
            95% { transform: scaleY(0.03); }
        }

        .thinking .eye {
            border-color: #ff0055;
            box-shadow: inset 0 0 40px rgba(255, 0, 85, 0.3);
            transform: scale(0.9);
        }
        .thinking .bright-lens {
            background-color: #ff0055;
            box-shadow: 0 0 45px #ff0055;
            width: 30%; height: 30%;
            animation: corePulse 0.5s infinite alternate ease-in-out;
        }
        @keyframes corePulse {
            0% { transform: scale(0.8); filter: brightness(1); }
            100% { transform: scale(1.2); filter: brightness(1.6); }
        }

        .speaking .eye {
            border-color: #00ffcc;
            animation: audioWaveBounce 0.18s infinite alternate ease-in-out;
        }
        @keyframes audioWaveBounce {
            0% { transform: scaleY(0.9) scaleX(1.05); }
            100% { transform: scaleY(1.3) scaleX(0.85); }
        }

        /* --- CONSOLE MANAGEMENT OPTIONS --- */
        #reset-btn {
            position: absolute; bottom: 15px; right: 15px;
            font-family: monospace; font-size: 11px; color: #003322;
            cursor: pointer; border: 1px solid #001a11; padding: 4px 10px; border-radius: 4px;
            transition: all 0.2s; text-transform: uppercase; letter-spacing: 1px;
            z-index: 50;
        }
        #reset-btn:hover {
            color: #ff0055; border-color: #ff0055; background: rgba(255, 0, 85, 0.05);
            box-shadow: 0 0 8px rgba(255, 0, 85, 0.2);
        }

        #webcam, #canvas { display: none; visibility: hidden; position: absolute; left: -9999px; }
    </style>
</head>
<body>

    <!-- Splash Launch Deck -->
    <div id="start-screen">
        <div id="start-content" class="api-box"></div>
    </div>

    <!-- Main Eye Box Layout -->
    <div class="face-container listening" id="face">
        <div class="eye"><div class="bright-lens" id="lens-left"></div></div>
        <div class="eye"><div class="bright-lens" id="lens-right"></div></div>
    </div>

    <!-- Administrative Overrides -->
    <div id="reset-btn">Reset Key</div>

    <video id="webcam" autoplay playsinline muted></video>
    <canvas id="canvas" width="320" height="240"></canvas>

    <script>
        const synth = window.speechSynthesis;
        const rec = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
        
        const face = document.getElementById('face');
        const startScreen = document.getElementById('start-screen');
        const startContent = document.getElementById('start-content');
        const video = document.getElementById('webcam');
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');
        const lenses = [document.getElementById('lens-left'), document.getElementById('lens-right')];
        
        let currentStatus = "listening";
        let siriVoice = null;

        rec.continuous = true; 
        rec.interimResults = false;

        // Validates storage buffers before triggering layout systems
        function checkStorageConfiguration() {
            const preservedToken = localStorage.getItem('SUCHBOT_API_KEY');
            if (preservedToken) {
                startContent.innerHTML = `<div style="cursor:pointer; font-size:22px;">INITIALIZE CORE SYSTEMS</div>`;
                startScreen.onclick = bootSystem;
            } else {
                startScreen.onclick = null; // Unbind screen dismiss mechanics
                startContent.innerHTML = `
                    <div style="margin-bottom: 5px; font-size:18px;">ENTER OPENAI API KEY</div>
                    <input type="password" id="api-input" class="api-input" placeholder="sk-...">
                    <button id="save-api-btn" class="api-btn">SAVE SECURELY</button>
                `;
                
                document.getElementById('save-api-btn').onclick = () => {
                    const cleanValue = document.getElementById('api-input').value.trim();
                    if (cleanValue.startsWith('sk-')) {
                        localStorage.setItem('SUCHBOT_API_KEY', cleanValue);
                        bootSystem();
                    } else {
                        alert("Invalid format. Key needs to begin with 'sk-'");
                    }
                };
            }
        }

        function initVoice() {
            const voices = synth.getVoices();
            siriVoice = voices.find(v => v.name.includes("Samantha") || v.name.includes("Google US Female") || v.name.includes("Zira")) || voices[0];
        }
        initVoice();
        if (speechSynthesis.onvoiceschanged !== undefined) speechSynthesis.onvoiceschanged = initVoice;

        function deepLookAround() {
            if (currentStatus === "listening") {
                const moveX = (Math.random() * 44 - 22) + "px";
                const moveY = (Math.random() * 30 - 15) + "px";
                lenses.forEach(lens => lens.style.transform = `translate(${moveX}, ${moveY})`);
            }
            setTimeout(deepLookAround, Math.random() * 2000 + 1000);
        }
        deepLookAround();

        async function secureHardwareClearance() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { width: 320, height: 240, facingMode: "user" }, 
                    audio: true 
                });
                video.srcObject = stream;
            } catch (err) {
                console.log("Hardware interface tracking offline.");
            }
        }

        function setRobotState(state) {
            currentStatus = state;
            face.className = `face-container ${state}`;
            if (state !== "listening") {
                lenses.forEach(lens => lens.style.transform = "translate(0px, 0px)");
            }
        }

        async function speak(text) {
            synth.cancel(); 
            const utter = new SpeechSynthesisUtterance(text);
            utter.voice = siriVoice;
            utter.rate = 1.25; 
            utter.pitch = 1.1; 
            
            utter.onstart = () => setRobotState('speaking');
            utter.onend = () => setRobotState('listening');
            
            synth.speak(utter);
        }

        rec.onresult = async (event) => {
            const speechInput = event.results[event.results.length - 1][0].transcript;
            setRobotState('thinking');

            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            const base64Frame = canvas.toDataURL('image/jpeg', 0.3);

            // Pull token directly out of local memory registers at runtime
            const runtimeToken = localStorage.getItem('SUCHBOT_API_KEY');

            try {
                const response = await fetch("https://api.openai.com/v1/chat/completions", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "Authorization": `Bearer ${runtimeToken}` },
                    body: JSON.stringify({
                        model: "gpt-4o-mini",
                        messages: [
                            { 
                                role: "system", 
                                content: "You are SuchBot, an advanced neon-cybernetic AI desktop companion. Answer the user's spoken question directly with absolute wit and charm. Keep responses extremely brief, sharp, and full of mechanical personality. Max 1 short sentence. Crucial rule: Never use emojis, symbols, or text emoticons under any circumstance." 
                            },
                            { 
                                role: "user", 
                                content: [
                                    { type: "text", text: speechInput }, 
                                    { type: "image_url", image_url: { url: base64Frame } }
                                ] 
                            }
                        ],
                        max_tokens: 25
                    })
                });
                
                const data = await response.json();
                speak(data.choices[0].message.content);
            } catch (err) {
                setRobotState('listening');
            }
        };

        rec.onend = () => {
            setTimeout(() => { try { rec.start(); } catch(e) {} }, 250);
        };

        async function bootSystem() {
            startScreen.style.display = 'none';
            await secureHardwareClearance();
            initVoice();
            try { rec.start(); } catch(e) {}
            setRobotState('listening');
        }

        // Wipe routine for key updating
        document.getElementById('reset-btn').onclick = () => {
            if (confirm("Wipe saved API Token out of browser memory?")) {
                localStorage.removeItem('SUCHBOT_API_KEY');
                window.location.reload();
            }
        };

        window.onload = checkStorageConfiguration;
    </script>
</body>
</html>
